# Required — Groq API key for speech-to-text (see https://console.groq.com/)
GROQ_API_KEY=

# HTTP server (defaults shown)
# PORT=6666
# HOST=0.0.0.0

# Redis for transcript streams (use redis://redis:6379 in Docker Compose)
# REDIS_URL=redis://localhost:6379

# Optional HTTP/WebSocket paths
# TRANSCRIPTION_HEALTH_PATH=/health
# TRANSCRIPTION_WS_PATH=/ws

# Model: GROQ_TRANSCRIPTION_MODEL wins over OPENAI_TRANSCRIPTION_MODEL (name kept for compatibility)
# Default in code: whisper-large-v3-turbo
# GROQ_TRANSCRIPTION_MODEL=whisper-large-v3-turbo

# Optional defaults passed to the transcription API
# OPENAI_TRANSCRIPTION_LANGUAGE=
# OPENAI_TRANSCRIPTION_PROMPT=

# Redis stream key prefix and max upload size per chunk (bytes)
# TRANSCRIPT_STREAM_PREFIX=transcript
# MAX_AUDIO_CHUNK_BYTES=26214400

# Save WebSocket audio to disk; a timer writes every N ms of wall time (does not wait for the meeting to end)
# TRANSCRIPTION_DEBUG_AUDIO_DIR=/data/transcription-debug-audio
# TRANSCRIPTION_DEBUG_AUDIO_WINDOW_MS=10000
