{
  "name": "meetingbot",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:backend": "npm run dev -w @meetingbot/backend",
    "dev:worker": "npm run dev -w @meetingbot/worker",
    "dev:frontend": "npm run dev -w @meetingbot/frontend",
    "test:join": "npm run cli:join -w @meetingbot/bot --"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2"
  }
}
